# EvDeğer Environment Variables
# Copy this file to .env and update values

# ── Database ──
POSTGRES_DB=evdeger
POSTGRES_USER=evdeger
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql+asyncpg://evdeger:your_secure_password_here@db:5432/evdeger

# ── Redis ──
REDIS_URL=redis://redis:6379

# ── Backend ──
SECRET_KEY=change-this-to-a-random-secret-key
BACKEND_PORT=8000
DEBUG=false

# ── Frontend ──
NEXT_PUBLIC_API_URL=https://evdeger.durinx.com/api
FRONTEND_PORT=3000

# ── Scraping (optional) ──
# SAHIBINDEN_API_KEY=
# HEPSIEMLAK_API_KEY=
